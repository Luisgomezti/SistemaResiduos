<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - SistemaResiduos</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/SistemaResiduos.styles.css"
          asp-append-version="true" />

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">

        <div class="container-fluid">

            <a class="navbar-brand fw-bold"
               href="/Home/Index">

                Inicio

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                           href="/Registros/Dashboard">

                            Panel de control    |

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           href="/Registros/Cargar">

                            Nuevo Registro     |

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           href="/Registros/Lista">

                            Historal

                        </a>

                    </li>

                    }
                    @if (Context.Session.GetString("Usuario") != null)
                    {
                        <li class="nav-item ms-3">

                            <span class="nav-link text-light">

                                👤 @Context.Session.GetString("Nombre")

                            </span>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link text-warning"
                               href="/Login/CerrarSesion">

                                Cerrar sesión

                            </a>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <div class="container-fluid">

        <main role="main"
              class="pb-3">

            @RenderBody()

        </main>

    </div>

    <footer class="border-top footer text-muted mt-5">

        <div class="container">

            &copy; 2026 - SistemaResiduos

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>