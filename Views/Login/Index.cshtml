@model SistemaResiduos.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Acceso al Sistema</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image: url('/images/nizuc-login.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

            body::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.60);
                z-index: 0;
            }

        .login-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 360px;
            padding: 30px;
            border-radius: 18px;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.10);
            color: white;

        }

        .titulo {

    font-size: 1.5rem;

    font-weight: 600;

    text-align: center;
}

        .subtitulo {
            text-align: center;
            margin-bottom: 30px;
            opacity: 0.9;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
        }

        .btn-login {
            background-color:cornflowerblue;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: bold;
        }

            .btn-login:hover {
                background-color: cornflowerblue
            }

        label {
            margin-bottom: 6px;
        }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="titulo">
            Sistema de Gestión de basura
        </div>

        <div class="subtitulo">
            Hotel Nizuc
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form method="post">

            <div class="mb-3">

                <label>Usuario</label>

                <input asp-for="Usuario"
                       class="form-control" />

            </div>

            <div class="mb-4">

                <label>Contraseña</label>

                <input asp-for="Password"
                       type="password"
                       class="form-control" />

            </div>

            <button type="submit"
                    class="btn btn-login w-100">

                Ingresar

            </button>

        </form>

    </div>

</body>

</html>