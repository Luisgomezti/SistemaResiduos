@model List<SistemaResiduos.Models.Registro>

    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h1 class="fw-bold">
                Historial de Registros
            </h1>

            <div>

                <a href="/Registros/ExportarExcel"
                   class="btn btn-success">

                    📥 Descargar Excel

                </a>

                <a href="/Registros/Cargar"
                   class="btn btn-dark">

                    ➕ Nuevo Registro

                </a>

            </div>

        </div>

        <div class="card p-4">

            <div class="table-responsive">

                <table class="table align-middle table-hover">

                    <thead>

                        <tr>

                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Área</th>
                            <th>Turno</th>
                            <th>Composta</th>
                            <th>No Compostable</th>
                            <th>Inorgánica</th>
                            <th>Fecha</th>
                            <th>Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                        <tr>

                            <td>@item.Id</td>

                            <td>@item.Hotel</td>

                            <td>@item.Area</td>

                            <td>@item.Turno</td>

                            <td class="text-success fw-bold">
                                @item.Composta
                            </td>

                            <td class="fw-bold">
                                @item.NoCompostable
                            </td>

                            <td class="text-dark fw-bold">
                                @item.Inorganica
                            </td>

                            <td>
                                @item.FechaRegistro
                            </td>

                            <td>

                                <a href="/Registros/Editar/@item.Id"
                                   class="btn btn-warning btn-sm">

                                    Editar

                                </a>

                                <a href="/Registros/Eliminar/@item.Id"
                                   class="btn btn-danger btn-sm">

                                    Eliminar

                                </a>

                            </td>

                        </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
